# Playit Platform - Environment Variables Template
# 아래의 변수들을 Supabase 대시보드에서 복사하여 '.env' 파일로 저장하세요.

# Supabase 프로젝트 URL (Settings -> API)
VITE_SUPABASE_URL=your_project_url_here

# Supabase 익명 키 (Settings -> API -> anon public)
VITE_SUPABASE_ANON_KEY=your_anon_key_here

# 기타 설정 (Optional)
VITE_APP_TITLE=Playit - Premium Gaming Admin
VITE_BASE_URL=/playit-platform/
