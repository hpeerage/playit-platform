import { createClient } from '@supabase/supabase-js';
import dotenv from 'dotenv';
dotenv.config();

const supabase = createClient(process.env.VITE_SUPABASE_URL || '', process.env.VITE_SUPABASE_ANON_KEY || '');

async function checkAdmin() {
  const { data: users, error: userError } = await supabase.auth.admin.listUsers();
  if (userError) {
    console.error('List Users Error:', userError);
  } else {
    const adminUser = users.users.find(u => u.email === 'admin@playit.com');
    if (adminUser) {
      console.log('Admin User Found in Auth:', adminUser.id);
      const { data: member, error: memberError } = await supabase
        .from('members')
        .select('*')
        .eq('user_id', adminUser.id)
        .maybeSingle();
      
      console.log('Member profile for admin:', member);
      if (memberError) console.error('Member fetch error:', memberError);
    } else {
      console.log('Admin User NOT found in Auth');
    }
  }
}

checkAdmin();
